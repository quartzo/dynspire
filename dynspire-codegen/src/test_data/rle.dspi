interface Rle {

  struct CompressionReport {
    original_size: u64,
    compressed_size: u64,
    ratio: f64,
    runs: u64,
  }

  struct NamedRun {
    label: DString,
    count: u64,
  }

  enum Tone {
    Quiet,
    Normal,
    Loud(u8),
  }

  fn compress(data: &[u8]) -> Vec<u8>;
  fn decompress(data: &[u8]) -> Vec<u8>;
  fn compress_into(data: &[u8], out: &mut Vec<u8>) -> ();
  fn stats(data: &[u8]) -> (u64, u64);
  fn analyze(data: &[u8]) -> CompressionReport;
  fn report_summary(report: CompressionReport) -> String;
  fn run_labels(data: &[u8]) -> Vec<String>;
  fn split_runs(data: &[u8]) -> Vec<Vec<u8>>;
  fn compress_into_checked(data: &[u8], out: &mut Vec<u8>) -> bool;
  fn first_byte(data: &[u8]) -> Option<u8>;
  fn classify(data: &[u8]) -> Tone;
  fn describe_tone(tone: Tone) -> String;
  fn delay(ms: u64) -> ();

  fn echo_bytes(data: &[u8]) -> DVec<u8>;
  fn build_string(data: &[u8]) -> DString;
  fn consume_dvec(data: DVec<u8>) -> u64;
  fn consume_dstring(s: DString) -> u64;
  fn view_len(s: DStr) -> u64;
  fn view_slice(data: DSlice<u8>) -> u64;
  fn probe(data: &[u8]) -> DOption<u8>;
  fn opt_classify(data: &[u8]) -> DOption<u8>;
  fn make_named_run(label: DString, count: u64) -> NamedRun;
}
